@model TrafficResultViewModel
@{
    ViewData["Title"] = "Inference Results";
    var videoMimeType = Model.VideoPath.EndsWith(".webm", StringComparison.OrdinalIgnoreCase) ? "video/webm" : "video/mp4";
    var vehicleLabels = System.Text.Json.JsonSerializer.Serialize(Model.VehicleTypeCounts.Keys);
    var vehicleValues = System.Text.Json.JsonSerializer.Serialize(Model.VehicleTypeCounts.Values);
}

<section class="result-header">
    <div>
        <span class="section-label">Inference Complete</span>
        <h1>Analysis Dashboard</h1>
    </div>
    <div class="d-flex gap-3">
        @if (!string.IsNullOrWhiteSpace(Model.CsvPath))
        {
            <a href="@Model.CsvPath" class="btn btn-outline-primary d-flex align-items-center gap-2" download>
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4M7 10l5 5 5-5M12 15V3"/></svg>
                Export CSV
            </a>
        }
        <a asp-controller="Home" asp-action="Index" class="btn btn-primary d-flex align-items-center gap-2">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
            New Process
        </a>
    </div>
</section>

<section class="stats-grid">
    <div class="stat-card">
        <span>Unique Vehicles</span>
        <strong>@Model.TotalVehicles</strong>
    </div>
    <div class="stat-card">
        <span>License Plates Read</span>
        <strong>@Model.TotalPlatesRead</strong>
    </div>
    <div class="stat-card">
        <span>Vehicle Classes</span>
        <strong>@Model.VehicleTypeCounts.Count</strong>
    </div>
</section>

<section class="row g-4 mb-4">
    <div class="col-lg-7">
        <div class="content-panel h-100 mb-0">
            <div class="panel-title mb-3">
                <h2 class="d-flex align-items-center gap-2">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="23 7 16 12 23 17 23 7"/><rect x="1" y="5" width="15" height="14" rx="2" ry="2"/></svg>
                    Processed Stream
                </h2>
            </div>
            @if (!string.IsNullOrWhiteSpace(Model.VideoPath))
            {
                <video class="processed-video" controls autoplay muted>
                    <source src="@Model.VideoPath" type="@videoMimeType" />
                    Your browser does not support the video tag.
                </video>
            }
            else
            {
                <div class="empty-state">No processed video available.</div>
            }
        </div>
    </div>
    <div class="col-lg-5">
        <div class="content-panel h-100 mb-0">
            <div class="panel-title mb-3">
                <h2 class="d-flex align-items-center gap-2">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M212 18V6a2 2 0 0 0-2-2H4a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2z"/><path d="M10 2v20"/><path d="M14 2v20"/><path d="M2 10h20"/><path d="M2 14h20"/></svg>
                    Class Distribution
                </h2>
            </div>
            <div class="d-flex align-items-center justify-content-center h-100 pb-4">
                <canvas id="vehicleTypeChart" height="250"></canvas>
            </div>
        </div>
    </div>
</section>

<section class="content-panel">
    <div class="panel-title mb-4">
        <h2 class="d-flex align-items-center gap-2">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>
            Detection Log
        </h2>
    </div>

    <div class="table-responsive">
        <table class="table table-hover align-middle traffic-table">
            <thead>
                <tr>
                    <th>Plate Number</th>
                    <th>Class</th>
                    <th>Confidence</th>
                    <th>Timestamp</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Records.Any())
                {
                    foreach (var item in Model.Records)
                    {
                        <tr>
                            <td><span class="plate-badge">@item.PlateNumber</span></td>
                            <td><span class="text-capitalize">@item.VehicleType</span></td>
                            <td>
                                <div class="d-flex align-items-center gap-2" style="min-width: 150px;">
                                    <div class="progress flex-grow-1" style="height: 6px; background-color: #374151;">
                                        <div class="progress-bar bg-primary" role="progressbar" style="width: @(item.Confidence * 100)%" aria-valuenow="@(item.Confidence * 100)" aria-valuemin="0" aria-valuemax="100"></div>
                                    </div>
                                    <span class="small font-monospace" style="min-width: 35px;">@item.Confidence.ToString("0.00")</span>
                                </div>
                            </td>
                            <td class="font-monospace text-muted">@item.TimeDetected.ToString("HH:mm:ss dd/MM/yyyy")</td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="4" class="text-center text-muted py-5">
                            <svg class="mb-3 opacity-50" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
                            <br/>
                            No high-confidence plate detections found.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</section>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        // Chart.js dark theme defaults
        Chart.defaults.color = '#9ca3af';
        Chart.defaults.borderColor = '#1f2937';
        
        window.trafficDashboardData = {
            vehicleLabels: @Html.Raw(vehicleLabels),
            vehicleValues: @Html.Raw(vehicleValues)
        };
    </script>
}